{
  "name": "@matheusmarnt/scoutify-mcp",
  "version": "0.1.2",
  "description": "MCP server for Scoutify Laravel package documentation and scaffolding",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "scoutify-mcp": "dist/server.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/matheusmarnt/scoutify-mcp.git"
  },
  "homepage": "https://github.com/matheusmarnt/scoutify-mcp#readme",
  "bugs": {
    "url": "https://github.com/matheusmarnt/scoutify-mcp/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "scoutify",
    "laravel",
    "mcp",
    "model-context-protocol",
    "scout"
  ],
  "scripts": {
    "build": "tsup src/server.ts --format esm --target node18 --out-dir dist",
    "test": "vitest run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "vitest": {
    "include": [
      "tests/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
